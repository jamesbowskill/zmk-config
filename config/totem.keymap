//             ┃           ┃     $     ┃     (     ┃     )     ┃     %     ┃   ┃     ¥     ┃     `     ┃     ^     ┃     ~     ┃     |     ┃
//             ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫
//             ┃           ┃     *     ┃     '     ┃     #     ┃     +     ┃   ┃   GLYPHS  ┃     @     ┃     !     ┃     ;     ┃     :     ┃
// ┏━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┓
// ┃  (held)   ┃     _     ┃     /     ┃     [     ┃     ]     ┃     =     ┃   ┃     &     ┃     "     ┃     {     ┃     }     ┃     \     ┃   (held)  ┃
// ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┫   ┣━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━╋━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛
//                                     ┃   PREV    ┃   PLAY    ┃   NEXT    ┃   ┃   MUTE    ┃  VOL DN   ┃  VOL UP   ┃
//                                     ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛   ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛
        bindings = <

                &none           &kp DOLLAR      &kp LPAR        &kp RPAR        &kp PERCENT           &kp INT_YEN    &kp GRAVE       &kp CARET      &kp TILDE       &kp PIPE
                &none           &kp ASTRK       &kp SQT         &kp HASH        &kp PLUS              &kp F4         &kp AT          &kp EXCL       &kp SEMI        &kp COLON
    &trans      &kp UNDER       &kp FSLH        &kp LBKT        &kp RBKT        &kp EQUAL             &kp AMPS       &kp DQT         &kp LBRC       &kp RBRC        &kp BACKSLASH     &trans
                                                &kp C_PREV      &kp C_PP        &kp C_NEXT            &kp C_MUTE     &kp C_VOL_DN    &kp C_VOL_UP
                >;
